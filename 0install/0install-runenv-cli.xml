      <archive extract="0install-runenv-cli-1.12" href="http://downloads.sourceforge.net/project/zero-install/runenv-cli/1.12/0install-runenv-cli-1.12.tar.bz2" size="4837"/>
    </implementation>
    <implementation id="sha1new=b86cd8995adf636b5bc0c7bdae789f18db76d7df" released="2012-10-06" stability="stable" version="1.13">
      <manifest-digest sha256="a702e205ed32c0a960b4ae4605eec42cfa818f489815cf340012cb5f47fb6441"/>
      <archive extract="0install-runenv-cli-1.13" href="http://downloads.sourceforge.net/project/zero-install/runenv-cli/1.13/0install-runenv-cli-1.13.tar.bz2" size="5695"/>
    </implementation>
    <group>
