<?xml version="1.0" ?>
<?xml-stylesheet type='text/xsl' href='../resources/feed.xsl'?>
<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/devel/google-api-linter.xml">
  <name>Google API Linter</name>
  <summary>API linter for Protocol Buffers (protobuf)</summary>
  <description>The API linter provides real-time checks for compliance with many of Google’s API standards, documented using API Improvement Proposals. It operates on API surfaces defined in protocol buffers.</description>
  <homepage>https://linter.aip.dev/</homepage>
  <category>Development</category>
  <needs-terminal/>

  <replaced-by interface="https://apps.0install.net/protobuf/google-api-linter.xml"/>
  <feed src="https://apps.0install.net/protobuf/google-api-linter.xml"/>

  <entry-point binary-name="api-linter" command="run"/>
</interface>
