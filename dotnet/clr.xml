<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/dotnet/clr.xml">
  <name>Common Language Runtime (CLR)</name>
  <summary>virtual feed for .NET implementations</summary>
  <description>Virtual feed for .NET implementations: .NET Framework on Windows and Mono on POSIX. Uses .NET Framework profiles as version numbers.</description>
  <icon href="https://apps.0install.net/dotnet/dotnet.png" type="image/png"/>

  <!-- The .NET Framework is an implementation of the Common Language Runtime. -->
  <feed arch="Windows-*" src="https://apps.0install.net/dotnet/framework.xml"/>

