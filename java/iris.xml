<?xml-stylesheet type='text/xsl' href='../resources/feed.xsl'?>
<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/java/iris.xml">
  <name>IRIS Reasoner</name>
  <summary>an extensible reasoning engine for expressive rule-based languages</summary>
  <description>
IRIS is an open-source Datalog reasoner that can evaluate safe or unsafe datalog
extended with function symbols, XML schema data types, built-in predicates and
(locally) stratified or well-founded negation as failure.</description>
  <homepage>http://www.iris-reasoner.org/</homepage>
  <group>
    <environment insert="iris-0.60.jar" name="CLASSPATH"/>
    <environment insert="iris-app-0.60.jar" name="CLASSPATH"/>
    <environment insert="iris-parser-0.60.jar" name="CLASSPATH"/>
    <command name="run">
      <runner interface="https://apps.0install.net/java/openjdk-6-jre.xml"/>
      <arg>org.deri.iris.demo.Demo</arg>
    </command>
    <implementation doc-dir="doc" id="sha1new=daf7bfada93ec758baeef1c714f3239ce0a5a462" license="GPL-2.0-only" released="2011-03-26" version="0.6.0">
      <archive href="http://downloads.sourceforge.net/project/iris-reasoner/iris-reasoner/iris%20v0.60/iris-0.60.zip" size="4329896" type="application/zip"/>
    </implementation>
  </group>
</interface>
