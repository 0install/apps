<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/javascript/pnpm.xml">
  <name>pnpm</name>
  <summary>fast, disk space efficient package manager for JavaScript</summary>
  <description>pnpm is a fast, disk space efficient package manager for JavaScript. It uses a content-addressable filesystem to store all files from all module directories on a disk, avoiding duplication and speeding up installation.</description>
  <homepage>https://pnpm.io/</homepage>
  <category>Development</category>
  <needs-terminal/>
  <icon href="https://apps.0install.net/javascript/pnpm.png" type="image/png"/>
  <icon href="https://apps.0install.net/javascript/pnpm.ico" type="image/vnd.microsoft.icon"/>

  <entry-point binary-name="pnpm" command="run"/>

