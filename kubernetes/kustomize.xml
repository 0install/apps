<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/kubernetes/kustomize.xml">
  <name>kustomize</name>
  <summary>customization of kubernetes YAML configurations</summary>
  <description>kustomize lets you customize raw, template-free YAML files for multiple purposes, leaving the original YAML untouched and usable as is. It targets Kubernetes; it understands and can patch Kubernetes style API objects. It's like make, in that what it does is declared in a file, and it's like sed, in that it makes structured edits to data without fully parsing it.</description>
  <homepage>https://kustomize.io/</homepage>
  <category>Development</category>
  <needs-terminal/>
  <icon href="https://apps.0install.net/kubernetes/kustomize.png" type="image/png"/>
  <icon href="https://apps.0install.net/kubernetes/kustomize.ico" type="image/vnd.microsoft.icon"/>

  <entry-point binary-name="kustomize" command="run"/>

