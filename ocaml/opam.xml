<interface xmlns="http://zero-install.sourceforge.net/2004/injector/interface" uri="https://apps.0install.net/ocaml/opam.xml">
  <name>opam</name>
  <summary>source-based package manager for OCaml</summary>
  <description>opam is the package manager for OCaml. It supports multiple simultaneous compiler installations, flexible package constraints, and a Git-friendly development workflow, and is the primary way to install OCaml compilers, tools and libraries.</description>
  <homepage>https://opam.ocaml.org/</homepage>
  <category>Development</category>
  <needs-terminal/>
  <icon href="https://apps.0install.net/ocaml/opam.png" type="image/png"/>
  <icon href="https://apps.0install.net/ocaml/opam.ico" type="image/vnd.microsoft.icon"/>

  <entry-point binary-name="opam" command="run"/>

  <group license="LGPL-2.1-only">
    <requires importance="recommended" interface="https://apps.0install.net/devel/git.xml">
      <executable-in-path name="git"/>
    </requires>

