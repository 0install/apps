    </implementation>
    <implementation arch="Windows-i486" version="2.22.0" stability="developer" id="sha1new=870fd5d1c2968e3da44232f492064a69ec70c0b8">
      <manifest-digest sha256new="674477UGD7YPVU4RYTGPVJ5EIXVQJJFIVB5YZ6C7Q66JZJREZJQA"/>
