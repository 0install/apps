<c:catalog xmlns:c="http://0install.de/schema/injector/catalog" xmlns="http://zero-install.sourceforge.net/2004/injector/interface"><interface uri="https://apps.0install.net/rust/rustup.xml"><name>rustup</name><summary>the Rust toolchain installer</summary><description>rustup installs the Rust programming language from the official release channels, enabling you to easily switch between stable, beta, and nightly compilers and keep them updated. It makes cross-compiling simpler with binary builds of the standard library for common platforms.</description><homepage>https://rust-lang.org/</homepage><category>Development</category><needs-terminal/><icon href="https://apps.0install.net/rust/rust.png" type="image/png"/><icon href="https://apps.0install.net/rust/rust.ico" type="image/vnd.microsoft.icon"/><entry-point binary-name="rustup" command="run">
    <needs-terminal/>
    <name>rustup</name>
    <summary>the Rust toolchain installer</summary>
  </entry-point><entry-point binary-name="cargo" command="cargo">
    <needs-terminal/>
    <name>cargo</name>
    <summary>the Rust package manager</summary>
  </entry-point><entry-point binary-name="rustc" command="rustc">
    <needs-terminal/>
    <name>rustc</name>
    <summary>the Rust compiler</summary>
  </entry-point><entry-point binary-name="rustdoc" command="rustdoc">
    <needs-terminal/>
    <name>rustdoc</name>
    <summary>generate documentation for a Rust crate</summary>
  </entry-point><entry-point binary-name="rustfmt" command="rustfmt">
    <needs-terminal/>
    <name>rustfmt</name>
    <summary>format Rust code</summary>
  </entry-point></interface></c:catalog>
